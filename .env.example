# ============================================================
# Petory 운영 환경변수 템플릿
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env 는 절대 Git에 커밋하지 마세요.
# ============================================================

# ── MySQL ───────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=petory
DB_USERNAME=petory_app
DB_PASSWORD=your_strong_db_password_here
DB_ROOT_PASSWORD=your_strong_root_password_here

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password_here

# ── JWT ─────────────────────────────────────────────────────
# openssl rand -base64 64 로 생성 (최소 256bit = 32자 이상)
JWT_SECRET=

# ── 프론트엔드 URL ───────────────────────────────────────────
FRONTEND_URL=https://your-domain.com

# ── Google OAuth2 ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Naver OAuth2 ────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 네이버 지도 API ──────────────────────────────────────────
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# ── Gmail SMTP ──────────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
# Gmail 앱 비밀번호 (계정 설정 > 보안 > 앱 비밀번호)
MAIL_PASSWORD=

# ── 파일 업로드 ──────────────────────────────────────────────
FILE_UPLOAD_DIR=/app/uploads

# ── Ollama (AI) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# ── Pet Data API ─────────────────────────────────────────────
PET_DATA_API_URL=http://localhost:8000
PET_DATA_API_KEY=

# ── Spring Boot Admin ────────────────────────────────────────
ADMIN_SERVER_URL=http://localhost:8080/admin-ui
